# ==============================================================
# Pixelio — Local environment variables (example)
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ==============================================================

# ---------- Google Analytics 4 ----------
# Get from: https://analytics.google.com → Admin → Data Streams → Web → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ---------- Microsoft Clarity (free heatmaps + session recordings) ----------
# Get from: https://clarity.microsoft.com → Create Project → Settings → Project ID
# Format: xxxxxxxxxx (10 char string)
NEXT_PUBLIC_CLARITY_ID=

# ---------- Google Search Console verification ----------
# Get from: https://search.google.com/search-console → Add property → "HTML tag" method
# Paste just the content value (the code inside content="...")
NEXT_PUBLIC_GSC_VERIFICATION=

# ---------- Contact form email destination ----------
# For /api/contact. If empty, submissions are logged to server console only.
# To enable real email delivery, add a Resend API key below + set FROM/TO emails.
CONTACT_EMAIL_TO=arielmindel10@gmail.com

# Resend (https://resend.com) — free tier: 100 emails/day
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@resend.dev
